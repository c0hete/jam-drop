# =========================================================
# jam-drop — plantilla de variables de entorno
# =========================================================
# Copia este archivo a .env (gitignored) y completa los valores.
# El .env NUNCA se commitea. El .env.example SI (es solo la plantilla).
# =========================================================

# Identidad de este equipo en la malla (nombre amigable que se mostrara a los demas)
JAMDROP_DEVICE_NAME=mi-pc

# IP de este equipo en la malla WireGuard
# (la asignada por wg-quick, ej. 10.10.0.2)
JAMDROP_BIND_IP=10.10.0.2

# Puerto donde escucha el daemon receptor
JAMDROP_PORT=7777

# Ruta del inbox (donde se guardan los archivos recibidos)
# Default: data dir del usuario + /jam-drop/inbox
# Dejalo vacio para usar el default. Si lo seteas, usa ruta absoluta.
JAMDROP_INBOX=

# Token compartido entre tus equipos (auth basica del MVP)
# Generalo con: openssl rand -hex 32
# DEBE ser el mismo en todos tus equipos.
JAMDROP_SHARED_TOKEN=

# Modo de log: trace | debug | info | warn | error
JAMDROP_LOG_LEVEL=info
